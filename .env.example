# etwin-bot env 配置
# 复制到 .env 后填实际值

# TG bot token（@BotFather 申请）
TG_BOT_TOKEN=

# Alice 的 chat ID
# 第一次启动后给 bot 发 /start，bot 会 reply 你的 chat ID
ALICE_CHAT_ID=

# 是否 dry-run（true = 不真调 LLM 不真发 TG，只 log 到 console）
ETWIN_DRY_RUN=true

# 是否启动 proactive self-loop（false = 纯 reactive 模式）
ETWIN_PROACTIVE=true

# 自动路由：普通话正常聊；明确查/读/改/跑/画图时自动动工具
ETWIN_TOOL_MODE=auto

# 多实例 / 后端配置
ETWIN_INSTANCE=cc
ETWIN_DISPLAY_NAME="CC Twin"
ETWIN_PERSONA=cc
ETWIN_REPLY_PROMPT=prompts/reply-cc.md
ETWIN_SELF_PROMPT=prompts/self-decision-cc.md
ETWIN_LLM_BACKEND=claude
ETWIN_DATA_DIR=data-cc-self
ETWIN_FILE_DIR=files-cc-self
ETWIN_RECALL_SCOPE=etwin:cc-self
ETWIN_RUN_ON_START=true

# self-loop 唤醒间隔（毫秒）。生产实跑 4 小时（14400000）——间隔只是检查频率，真发不发由 LLM 决策
ETWIN_WAKE_INTERVAL_MS=14400000

# mini ssh 配置
MINI_SSH_HOST=mini
CLAUDE_CLI_PATH=$HOME/.local/bin/claude

# Claude SDK 单次调用超时（毫秒），默认 10 分钟；到期会 abort SDK query
ETWIN_CLAUDE_TIMEOUT_MS=600000
# 兼容旧配置：LLM_TIMEOUT_MS 仍作为 Claude/Codex 的共享 fallback
# LLM_TIMEOUT_MS=600000
ETWIN_CLAUDE_SELF_LOOP_MAX_TURNS=1
ETWIN_CLAUDE_REACTIVE_MAX_TURNS=30
ETWIN_ENABLE_CODEX_MCP=false
ETWIN_REACTIVE_HISTORY_LIMIT=20
ETWIN_REACTIVE_STALL_NOTICE_MS=0
ETWIN_IMAGE_PROVIDER=codex-native
ETWIN_IMAGE_TIMEOUT_MS=600000
# 只在显式选择 Gemini 图片 provider 时使用；默认从 $HOME 推导
# ETWIN_CONTENT_PUBLISHER_DIR=$HOME/content-publisher
# ETWIN_IMAGE_CLI=scripts/gemini-web-image/gemini-web-image.ts
