# etwin-bot env 配置
# 复制到 .env 后填实际值

# TG bot token（@BotFather 申请）
TG_BOT_TOKEN=

# Alice 的 chat ID
# 第一次启动后给 bot 发 /start，bot 会 reply 你的 chat ID
ALICE_CHAT_ID=

# 是否 dry-run（true = 不真调 LLM 不真发 TG，只 log 到 console）
ETWIN_DRY_RUN=true

# 是否启动 proactive self-loop（false = 纯 reactive 模式）
ETWIN_PROACTIVE=true

# 工具模式：auto = 普通聊天禁工具，明确查/读/改/跑时开全工具；也可用 /chat 或 /full 手动指定
ETWIN_TOOL_MODE=auto

# 多实例 / 后端配置
ETWIN_INSTANCE=cc
ETWIN_DISPLAY_NAME="CC Twin"
ETWIN_PERSONA=cc
ETWIN_REPLY_PROMPT=prompts/reply-cc.md
ETWIN_SELF_PROMPT=prompts/self-decision-cc.md
ETWIN_LLM_BACKEND=claude
ETWIN_DATA_DIR=data-cc-self
ETWIN_FILE_DIR=files-cc-self
ETWIN_RECALL_SCOPE=etwin:cc-self
ETWIN_RUN_ON_START=true

# self-loop 唤醒间隔（毫秒），默认 30 分钟
ETWIN_WAKE_INTERVAL_MS=1800000

# mini ssh 配置
MINI_SSH_HOST=mini
MINI_CLAUDE_BIN=/Users/anxianjingya/.local/bin/claude

# LLM 单次调用超时（毫秒），默认 120 秒
LLM_TIMEOUT_MS=120000
ETWIN_CLAUDE_SELF_LOOP_MAX_TURNS=1
ETWIN_CLAUDE_REACTIVE_MAX_TURNS=30
ETWIN_REACTIVE_HISTORY_LIMIT=20
ETWIN_REACTIVE_STALL_NOTICE_MS=0
ETWIN_IMAGE_MODEL=gemini-2.5-flash
ETWIN_IMAGE_TIMEOUT_MS=360000
