{
  "name": "etwin-bot",
  "version": "0.2.0",
  "description": "Single-user proactive Telegram companion with Claude Agent SDK and Codex backends.",
  "type": "module",
  "main": "bot.js",
  "scripts": {
    "start": "bun run bot.js",
    "dryrun": "ETWIN_DRY_RUN=true bun run bot.js",
    "tick": "bun -e 'import(\"./self-loop.js\").then(m => m.selfTick({ dryRun: process.env.ETWIN_DRY_RUN === \"true\" }))'",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "grammy": "^1.30.0",
    "https-proxy-agent": "^9.0.0"
  },
  "overrides": {
    "hono": "^4.12.30",
    "qs": "^6.15.3"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "bun": ">=1.3.12"
  }
}
