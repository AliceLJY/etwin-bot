# etwin-bot Codex 实例 env 模板
# 复制为 .env.codex 后填 TG_BOT_TOKEN

TG_BOT_TOKEN=
ALICE_CHAT_ID=

ETWIN_INSTANCE=codex
ETWIN_DISPLAY_NAME="Codex Twin"
ETWIN_PERSONA=codex
ETWIN_REPLY_PROMPT=prompts/reply-codex.md
ETWIN_LLM_BACKEND=codex
ETWIN_CODEX_MODEL=gpt-5.5
ETWIN_CODEX_TIMEOUT_MS=600000
ETWIN_CODEX_CHAT_TIMEOUT_MS=300000
ETWIN_CODEX_FULL_TIMEOUT_MS=600000
ETWIN_CODEX_CHAT_MAX_ATTEMPTS=2
ETWIN_CODEX_REASONING_EFFORT=xhigh
ETWIN_CODEX_SERVICE_TIER=fast
ETWIN_TOOL_MODE=auto
ETWIN_CODEX_CHAT_SANDBOX=read-only
ETWIN_CODEX_FULL_SANDBOX=workspace-write
ETWIN_CODEX_CHAT_IGNORE_USER_CONFIG=true
ETWIN_CODEX_FULL_IGNORE_USER_CONFIG=false
ETWIN_CODEX_CHAT_EPHEMERAL=true
ETWIN_ENABLE_CODEX_MCP=false
ETWIN_TYPING_KEEPALIVE_MS=4500
ETWIN_REACTIVE_HISTORY_LIMIT=16
ETWIN_REACTIVE_STALL_NOTICE_MS=120000
ETWIN_IMAGE_PROVIDER=codex-native
ETWIN_IMAGE_TIMEOUT_MS=600000

ETWIN_DATA_DIR=data-codex
ETWIN_FILE_DIR=files-codex
ETWIN_RECALL_SCOPE=etwin:codex

ETWIN_DRY_RUN=false
# Codex 版轻心跳：主动但轻；self-loop 只做关心判断，不跑 full 工具链路
ETWIN_PROACTIVE=true
ETWIN_RUN_ON_START=false
ETWIN_WAKE_INTERVAL_MS=14400000
ETWIN_SELF_PROMPT=prompts/self-decision-codex.md

LLM_TIMEOUT_MS=600000
